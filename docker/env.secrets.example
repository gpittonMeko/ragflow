# Stripe Configuration Template
# Copy this file to .env.secrets and fill in your real keys
# IMPORTANT: .env.secrets is in .gitignore and will NEVER be committed to git
#
# To use this:
#   1. Copy: cp env.secrets.example .env.secrets
#   2. Edit .env.secrets and add your real Stripe keys
#   3. Never commit .env.secrets to git!
#
# Get these keys from: https://dashboard.stripe.com/apikeys

STRIPE_SECRET_KEY=sk_test_your_secret_key_here
STRIPE_PRICE_PREMIUM=price_your_price_id_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here
# Canonical URL for Stripe return URLs and cookie paths; use the host your users bookmark.
APP_URL=https://www.sgailegal.com

# Optional: comma-separated list to restrict CORS (default: apex + www + app.sgailegal.com for HTTPS)
# OAUTH_CORS_ORIGINS=https://sgailegal.com,https://www.sgailegal.com,https://app.sgailegal.com

# Google Cloud Console → Credentials → OAuth client → Authorized JavaScript origins must include
# every host users open in the browser, e.g. https://sgailegal.com and https://www.sgailegal.com
# (and https://app.sgailegal.com if used).

# Note: These keys are automatically loaded by docker-compose-base.yml
# The backendoauth service will use them via the environment section

